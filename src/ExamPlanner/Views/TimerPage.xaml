<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ExamPlanner.Views.TimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
    xmlns:controls="clr-namespace:ExamPlanner.Controls"
    x:DataType="vm:TimerViewModel"
    Title="{Binding Title}">
    <Grid>
    <controls:SquaresBackgroundView />
    <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="10">

        <Label Text="{Binding ElapsedText}" FontFamily="InterSemibold" FontSize="54"
               HorizontalOptions="Center" />

        <controls:StudyTreeView Fraction="{Binding TreeFraction}"
                                HeightRequest="140" HorizontalOptions="Fill" />

        <Label Text="{Binding ProgressText}" Style="{StaticResource SecondaryLabel}"
               HorizontalOptions="Center" />

        <Label Text="{Binding GoalText}" Style="{StaticResource SuccessLabel}"
               FontFamily="InterSemibold" HorizontalOptions="Center"
               IsVisible="{Binding GoalVisible}" />

        <Border Style="{StaticResource Card}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Тема" Style="{StaticResource SecondaryLabel}" />
                <Picker Title="Тема" ItemsSource="{Binding Topics}"
                        ItemDisplayBinding="{Binding Title}"
                        SelectedIndex="{Binding SelectedTopicIndex}" />
            </VerticalStackLayout>
        </Border>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="Старт" Command="{Binding StartCommand}"
                    IsVisible="{Binding IsRunning, Converter={StaticResource InvertBool}}" />
            <Button Grid.Column="0" Text="Пауза" Command="{Binding PauseCommand}"
                    Style="{StaticResource TonalButton}"
                    IsVisible="{Binding IsRunning}" />
            <Button Grid.Column="1" Text="Стоп" Command="{Binding StopCommand}"
                    Style="{StaticResource DangerButton}" />
        </Grid>

        <Label Text="{Binding StatusText}" Style="{StaticResource SuccessLabel}"
               HorizontalOptions="Center" />
    </VerticalStackLayout>
    </ScrollView>
    </Grid>
</ContentPage>
