<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ExamPlanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ExamPlanner.Views"
    Title="ExamPlanner">

    <TabBar>
        <ShellContent Title="Экзамены" Icon="ic_exams.png" Route="dashboard" ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Title="Сегодня" Icon="ic_today.png" Route="today" ContentTemplate="{DataTemplate views:TodayPage}" />
        <ShellContent Title="Статистика" Icon="ic_stats.png" Route="stats" ContentTemplate="{DataTemplate views:StatsPage}" />
        <ShellContent Title="Настройки" Icon="ic_settings.png" Route="settings" ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>
