<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ==========================================================
         ExamPlanner design system — dark-green / gray / black palette.
         Raw swatches carry a Light / Dark suffix; semantic + control
         styles in Styles.xaml pick between them with AppThemeBinding,
         so a single UserAppTheme toggle re-themes the whole app.
         All body-text pairings verified >= WCAG AA (4.5:1).
         Note: For Android see also Platforms\Android\Resources\values\colors.xml
         ========================================================== -->

    <!-- Green accent (muted dark green) -->
    <Color x:Key="AccentGreenLight">#2E6B4F</Color>
    <Color x:Key="AccentGreenDark">#4E9E77</Color>
    <!-- Text/icon drawn on top of the accent (button labels) -->
    <Color x:Key="OnAccentLight">#FFFFFF</Color>
    <Color x:Key="OnAccentDark">#08110C</Color>
    <!-- Soft green tint used for subtle fills / selected states -->
    <Color x:Key="AccentTintLight">#C3D8CB</Color>
    <Color x:Key="AccentTintDark">#1F4A38</Color>
    <!-- Text drawn on the tint (tonal buttons) -->
    <Color x:Key="OnTintLight">#1F4A38</Color>
    <Color x:Key="OnTintDark">#A9E8C6</Color>

    <!-- Neutrals: soft gray-green surfaces (light) to near-black (dark) -->
    <Color x:Key="PageBackgroundLight">#D8E1D9</Color>
    <Color x:Key="PageBackgroundDark">#0F1311</Color>
    <Color x:Key="SurfaceLight">#E8EEE8</Color>
    <Color x:Key="SurfaceDark">#1A211D</Color>
    <Color x:Key="PrimaryTextLight">#18201B</Color>
    <Color x:Key="PrimaryTextDark">#E7ECE9</Color>
    <Color x:Key="SecondaryTextLight">#49524C</Color>
    <Color x:Key="SecondaryTextDark">#A6B0AA</Color>
    <Color x:Key="BorderLight">#BFCBC1</Color>
    <Color x:Key="BorderDark">#2E3833</Color>

    <!-- Status colors -->
    <Color x:Key="DangerLight">#B3261E</Color>
    <Color x:Key="DangerDark">#F2B8B5</Color>
    <Color x:Key="WarningLight">#7E4B00</Color>
    <Color x:Key="WarningDark">#E0A85A</Color>

    <!-- ==========================================================
         Template-compatible keys (consumed by Styles.xaml), remapped
         onto the green palette so no purple remains.
         ========================================================== -->
    <Color x:Key="Primary">#2E6B4F</Color>
    <Color x:Key="PrimaryDark">#4E9E77</Color>
    <Color x:Key="PrimaryDarkText">#08110C</Color>
    <Color x:Key="Secondary">#CFE3D8</Color>
    <Color x:Key="SecondaryDarkText">#4E9E77</Color>
    <Color x:Key="Tertiary">#1F4A38</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#0F1311</Color>
    <Color x:Key="Magenta">#2E6B4F</Color>
    <Color x:Key="MidnightBlue">#2E6B4F</Color>
    <Color x:Key="OffBlack">#0F1311</Color>

    <Color x:Key="Gray100">#E8EDE9</Color>
    <Color x:Key="Gray200">#D5DDD8</Color>
    <Color x:Key="Gray300">#B4BFB8</Color>
    <Color x:Key="Gray400">#8B968F</Color>
    <Color x:Key="Gray500">#697169</Color>
    <Color x:Key="Gray600">#3A423D</Color>
    <Color x:Key="Gray900">#1A211D</Color>
    <Color x:Key="Gray950">#0F1311</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
